{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Document Plan",
  "type": "object",
  "required": ["title", "audience", "goal", "outputRoute", "sections"],
  "properties": {
    "title": { "type": "string" },
    "audience": { "type": "string" },
    "goal": { "type": "string" },
    "outputRoute": { "type": "string" },
    "archetype": { "type": "string" },
    "designPreset": { "type": "string" },
    "tone": { "type": "string" },
    "sourceMaterials": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heading", "purpose"],
        "properties": {
          "heading": { "type": "string" },
          "purpose": { "type": "string" },
          "formFactor": { "type": "string" },
          "source": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "verificationPlan": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
