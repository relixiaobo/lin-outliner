{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Data Validation Report",
  "type": "object",
  "required": ["file", "contract", "ok", "errors", "warnings", "checks"],
  "properties": {
    "file": { "type": "string" },
    "contract": { "type": "string" },
    "ok": { "type": "boolean" },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "warning", "failed"] },
          "details": {}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
