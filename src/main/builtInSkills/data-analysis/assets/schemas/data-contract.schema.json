{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portable Data Contract",
  "type": "object",
  "properties": {
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["string", "number", "date", "boolean", "empty"] },
          "required": { "type": "boolean" },
          "unique": { "type": "boolean" },
          "min": {},
          "max": {},
          "allowedValues": {
            "type": "array",
            "items": {}
          }
        },
        "additionalProperties": false
      }
    },
    "uniqueKeys": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "rowCountMin": { "type": "integer" },
    "rowCountMax": { "type": "integer" }
  },
  "additionalProperties": false
}
