{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Data Analysis Verification Report",
  "type": "object",
  "required": ["artifact", "outputRoute", "checks", "issues", "limitations", "finalStatus"],
  "properties": {
    "artifact": { "type": "string" },
    "outputRoute": { "type": "string" },
    "filesProduced": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sourceMaterials": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "warning", "failed", "skipped"] },
          "tool": { "type": "string" },
          "evidence": { "type": "string" },
          "result": {}
        },
        "additionalProperties": false
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "description"],
        "properties": {
          "severity": { "type": "string", "enum": ["info", "warning", "error"] },
          "description": { "type": "string" },
          "fixed": { "type": "boolean" },
          "status": { "type": "string", "enum": ["open", "fixed", "accepted"] }
        },
        "additionalProperties": false
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "finalStatus": { "type": "string", "enum": ["passed", "warning", "failed"] }
  },
  "additionalProperties": false
}
