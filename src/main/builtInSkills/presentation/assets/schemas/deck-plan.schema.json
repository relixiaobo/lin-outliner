{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deck Plan",
  "type": "object",
  "required": ["title", "audience", "goal", "outputRoute", "slides"],
  "properties": {
    "title": { "type": "string" },
    "audience": { "type": "string" },
    "goal": { "type": "string" },
    "outputRoute": { "type": "string" },
    "visualTemperament": { "type": "string" },
    "visualSystem": {
      "type": "object",
      "properties": {
        "direction": { "type": "string" },
        "stylePack": { "type": "string" },
        "theme": { "type": "string" },
        "motif": { "type": "string" },
        "typography": { "type": "string" },
        "layoutRules": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "sourceMaterials": {
      "type": "array",
      "items": { "type": "string" }
    },
    "storySpine": {
      "type": "array",
      "items": { "type": "string" }
    },
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slide", "purpose", "headline", "visual"],
        "properties": {
          "slide": { "type": ["integer", "string"] },
          "purpose": { "type": "string" },
          "headline": { "type": "string" },
          "evidence": { "type": "string" },
          "layout": { "type": "string" },
          "visualRole": { "type": "string" },
          "visual": { "type": "string" },
          "assetPlan": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "verificationPlan": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
