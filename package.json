{
  "name": "lin-outliner",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first desktop outliner with an Electron shell and TypeScript core",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:main": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-main\" electron-vite dev",
    "dev:cc": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-cc\" electron-vite dev",
    "dev:cc-2": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-cc-2\" electron-vite dev",
    "dev:codex": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-codex\" electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "vite preview",
    "app:dev": "electron-vite dev",
    "renderer:dev": "vite --host 127.0.0.1",
    "app:build": "electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test:core": "bun test --path-ignore-patterns 'tmp/**' tests/core",
    "test:renderer": "bun test --path-ignore-patterns 'tmp/**' tests/renderer",
    "test:e2e": "playwright test",
    "probe:web-tools": "bun build scripts/probe-web-tools.ts --outfile scripts/.out/probe-web-tools.cjs --target node --format cjs --external electron && electron scripts/.out/probe-web-tools.cjs"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.75.4",
    "@earendil-works/pi-ai": "0.75.4",
    "defuddle": "0.18.1",
    "linkedom": "0.18.12",
    "loro-crdt": "^1.10.6",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.4",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remend": "^1.2.2",
    "shiki": "^4.1.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.3",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  },
  "build": {
    "appId": "com.linoutliner.desktop",
    "productName": "Lin Outliner",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "identity": null
    }
  },
  "trustedDependencies": [
    "electron"
  ]
}
