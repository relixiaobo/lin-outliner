{
  "name": "lin-outliner",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first structured thinking and agent workbench",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:main": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-main\" electron-vite dev",
    "dev:cc": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-cc\" electron-vite dev",
    "dev:cc-2": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-cc-2\" electron-vite dev",
    "dev:codex": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-codex\" electron-vite dev",
    "dev:codex-2": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-codex-2\" electron-vite dev",
    "dev:codex-3": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-codex-3\" electron-vite dev",
    "dev:codex-4": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-codex-4\" electron-vite dev",
    "dev:anti": "ELECTRON_USER_DATA_DIR=\"$HOME/.lin-outliner-anti\" electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "skills:sync": "bun scripts/sync-built-in-skills.ts",
    "import-cli:build": "bun build src/main/builtInSkills/data-cleanup/scripts/tenon-import.ts --outfile build/generated/tenon-import/tenon-import.mjs --target node --format esm",
    "preview": "vite preview",
    "app:dev": "electron-vite dev",
    "renderer:dev": "vite --host 127.0.0.1",
    "build:native": "node-gyp rebuild --directory=native/window-corner --runtime=electron --target=$(node -p \"require('electron/package.json').version\") --dist-url=https://electronjs.org/headers && node-gyp rebuild --directory=native/browser-tab --runtime=electron --target=$(node -p \"require('electron/package.json').version\") --dist-url=https://electronjs.org/headers",
    "app:build": "bun run build:native && electron-vite build && bun run skills:sync && bun run import-cli:build && electron-builder",
    "typecheck": "tsc --noEmit",
    "docs:check": "bun scripts/docs-check.ts",
    "test:core": "bun test --path-ignore-patterns 'tmp/**' tests/core",
    "test:renderer": "bun test --path-ignore-patterns 'tmp/**' tests/renderer",
    "test:e2e": "playwright test",
    "test:smoke": "electron-vite build && playwright test --config=playwright.smoke.config.ts",
    "probe:web-tools": "bun build scripts/probe-web-tools.ts --outfile scripts/.out/probe-web-tools.cjs --target node --format cjs --external electron && electron scripts/.out/probe-web-tools.cjs",
    "probe:asset-hashing": "bun build scripts/probe-asset-hashing.ts --outfile scripts/.out/probe-asset-hashing.cjs --target node --format cjs --external electron && electron scripts/.out/probe-asset-hashing.cjs"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.6",
    "@earendil-works/pi-ai": "0.80.6",
    "defuddle": "0.18.1",
    "foliate-js": "^1.0.1",
    "linkedom": "0.18.12",
    "loro-crdt": "^1.10.6",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.4",
    "media-chrome": "^4.19.2",
    "pdfjs-dist": "^6.0.227",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remend": "^1.2.2",
    "shiki": "^4.1.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.3",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  },
  "build": {
    "appId": "dev.linlab.tenon",
    "productName": "Tenon",
    "copyright": "© 2026 Lin Lab",
    "afterPack": "build/afterPack.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "native/window-corner/build/Release/window_corner.node",
        "to": "native/window_corner.node"
      },
      {
        "from": "native/browser-tab/build/Release/browser_tab.node",
        "to": "native/browser_tab.node"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "vendor/ripgrep",
        "to": "ripgrep",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/generated/built-in-skills",
        "to": "built-in-skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/generated/tenon-import",
        "to": "tenon-import",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": "dmg",
      "identity": null
    },
    "linux": {
      "icon": "build/icon.png"
    }
  },
  "trustedDependencies": [
    "electron"
  ]
}
