{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lin Outliner",
  "version": "0.1.0",
  "identifier": "com.linoutliner.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:tauri",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lin Outliner",
        "width": 1120,
        "height": 820,
        "minWidth": 760,
        "minHeight": 560,
        "backgroundColor": "#f7f6f1",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
